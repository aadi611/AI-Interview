# ─── LLM ────────────────────────────────────────────────────────────────────
LLM_PROVIDER=           # openai | claude | ollama
# LLM_MODEL=                  # optional override; falls back to OPENAI_MODEL below

OPENAI_API_KEY=
OPENAI_MODEL= # replace with your model ID, e.g. gpt-4.1, o3, gpt-4o

# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─── APP ────────────────────────────────────────────────────────────────────
SECRET_KEY=
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_interview

# ─── REDIS ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── STORAGE ────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local | s3
STORAGE_LOCAL_PATH=./recordings

# AWS S3 (only needed if STORAGE_BACKEND=s3)
# AWS_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# ─── SPEECH ─────────────────────────────────────────────────────────────────
WHISPER_MODEL=base            # base | small | medium | large
TTS_PROVIDER=gtts             # gtts | elevenlabs
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
